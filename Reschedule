<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Reschedule — We've Got The Key</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Barlow:wght@400;600;700&family=Barlow+Condensed:wght@700;900&display=swap');

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --orange: #FF6B00;
      --orange-dark: #cc5500;
      --black: #0e0e0e;
      --card: #1a1a1a;
      --border: #2e2e2e;
      --text: #ffffff;
      --muted: #888888;
      --success: #22c55e;
    }

    html { -webkit-text-size-adjust: 100%; background: var(--black); }

    body {
      min-height: 100dvh;
      background: var(--black);
      color: var(--text);
      font-family: 'Barlow', sans-serif;
      font-size: 16px;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
      padding-bottom: calc(24px + env(safe-area-inset-bottom));
    }

    /* HEADER */
    .header { padding: 20px 20px 0; }

    .logo-top {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 20px;
      text-transform: uppercase;
      letter-spacing: 0.02em;
    }

    .logo-key { color: var(--orange); }

    .logo-sub {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--orange);
      margin-top: 1px;
    }

    /* HERO */
    .hero {
      padding: 28px 20px 24px;
      border-bottom: 1px solid var(--border);
    }

    .hero-eyebrow {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--orange);
      margin-bottom: 8px;
    }

    .hero-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 38px;
      line-height: 1.0;
      text-transform: uppercase;
    }

    .hero-title span { color: var(--orange); }

    .hero-sub {
      margin-top: 10px;
      font-size: 14px;
      color: var(--muted);
      line-height: 1.55;
    }

    .job-badge {
      display: flex;
      align-items: center;
      gap: 8px;
      background: var(--card);
      border: 1px solid var(--border);
      border-left: 3px solid var(--orange);
      padding: 10px 14px;
      border-radius: 6px;
      margin-top: 18px;
      font-size: 13px;
      color: var(--muted);
    }

    .job-badge strong { color: var(--text); font-weight: 700; }

    /* FORM */
    .form-wrap { padding: 24px 20px 40px; }

    .form-section { margin-bottom: 28px; }

    .form-label {
      display: block;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 10px;
    }

    .form-hint {
      font-size: 12px;
      color: var(--muted);
      margin-top: -6px;
      margin-bottom: 12px;
      opacity: 0.8;
      text-transform: none;
      letter-spacing: 0;
      font-weight: 400;
    }

    /* DATE CARDS — 2 col grid */
    .date-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .date-card {
      background: var(--card);
      border: 1.5px solid var(--border);
      border-radius: 10px;
      padding: 14px 12px;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
      touch-action: manipulation;
      transition: border-color 0.15s, background 0.15s;
      display: flex;
      align-items: center;
      gap: 10px;
      user-select: none;
    }

    .date-card.selected {
      border-color: var(--orange);
      background: rgba(255,107,0,0.09);
    }

    .date-card-check {
      width: 22px;
      height: 22px;
      border-radius: 5px;
      border: 2px solid var(--border);
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: border-color 0.15s, background 0.15s;
      font-size: 13px;
    }

    .date-card.selected .date-card-check {
      border-color: var(--orange);
      background: var(--orange);
      color: #fff;
    }

    .date-card-text { flex: 1; min-width: 0; }

    .date-card-day {
      font-size: 15px;
      font-weight: 700;
      color: var(--text);
      display: block;
    }

    .date-card.selected .date-card-day { color: var(--orange); }

    .date-card-date {
      font-size: 12px;
      color: var(--muted);
      display: block;
      margin-top: 1px;
    }

    /* TIME OPTIONS — stacked */
    .time-options { display: flex; flex-direction: column; gap: 10px; }

    .time-option input[type="radio"] { display: none; }

    .time-option label {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 16px 14px;
      background: var(--card);
      border: 1.5px solid var(--border);
      border-radius: 10px;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
      touch-action: manipulation;
      transition: border-color 0.15s, background 0.15s;
    }

    .time-icon { font-size: 24px; flex-shrink: 0; width: 32px; text-align: center; }
    .time-text { flex: 1; }

    .time-label {
      display: block;
      font-size: 15px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .time-desc {
      display: block;
      font-size: 12px;
      color: var(--muted);
      margin-top: 1px;
    }

    .time-check {
      width: 22px;
      height: 22px;
      border-radius: 50%;
      border: 2px solid var(--border);
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: border-color 0.15s, background 0.15s;
    }

    .time-option input:checked + label {
      border-color: var(--orange);
      background: rgba(255,107,0,0.09);
    }

    .time-option input:checked + label .time-label { color: var(--orange); }

    .time-option input:checked + label .time-check {
      border-color: var(--orange);
      background: var(--orange);
    }

    .time-option input:checked + label .time-check::after {
      content: '';
      display: block;
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #fff;
    }

    /* TEXTAREA */
    textarea {
      width: 100%;
      background: var(--card);
      border: 1.5px solid var(--border);
      border-radius: 10px;
      padding: 16px;
      color: var(--text);
      font-family: 'Barlow', sans-serif;
      font-size: 16px;
      line-height: 1.5;
      resize: none;
      min-height: 100px;
      outline: none;
      -webkit-appearance: none;
    }

    textarea::placeholder { color: var(--muted); }
    textarea:focus { border-color: var(--orange); }

    /* NOTICE */
    .notice {
      display: flex;
      gap: 12px;
      background: rgba(255,107,0,0.06);
      border: 1px solid rgba(255,107,0,0.2);
      border-radius: 10px;
      padding: 14px 16px;
      margin-bottom: 22px;
    }

    .notice-icon { font-size: 16px; flex-shrink: 0; margin-top: 2px; }

    .notice-text { font-size: 13px; color: var(--muted); line-height: 1.5; }
    .notice-text strong { color: var(--text); }

    /* ERROR */
    .error-msg {
      display: none;
      background: rgba(239,68,68,0.1);
      border: 1px solid rgba(239,68,68,0.3);
      border-radius: 8px;
      padding: 12px 16px;
      font-size: 13px;
      color: #f87171;
      margin-bottom: 14px;
    }

    /* SUBMIT */
    .btn-submit {
      display: block;
      width: 100%;
      background: var(--orange);
      color: #fff;
      border: none;
      border-radius: 12px;
      padding: 20px 24px;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 20px;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
      touch-action: manipulation;
      transition: background 0.15s, transform 0.1s;
    }

    .btn-submit:active { transform: scale(0.97); background: var(--orange-dark); }
    .btn-submit:disabled { background: #333; color: #555; cursor: not-allowed; }

    /* SUCCESS */
    .success-screen {
      display: none;
      padding: 60px 24px 48px;
      text-align: center;
    }

    .success-icon {
      width: 80px;
      height: 80px;
      background: rgba(34,197,94,0.1);
      border: 2px solid var(--success);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 36px;
      margin: 0 auto 24px;
    }

    .success-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 36px;
      text-transform: uppercase;
      margin-bottom: 12px;
    }

    .success-title span { color: var(--success); }

    .success-text {
      font-size: 15px;
      color: var(--muted);
      line-height: 1.6;
      max-width: 300px;
      margin: 0 auto 28px;
    }

    .success-dates {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 16px;
      text-align: left;
      margin-bottom: 16px;
    }

    .success-dates-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 8px;
    }

    .success-dates-list {
      font-size: 14px;
      color: var(--text);
      font-weight: 600;
      line-height: 1.8;
    }

    .success-ref {
      display: inline-block;
      background: var(--card);
      border: 1px solid var(--border);
      border-left: 3px solid var(--success);
      padding: 10px 16px;
      border-radius: 6px;
      font-size: 13px;
      color: var(--muted);
    }

    .success-ref strong { color: var(--text); }

    /* FOOTER */
    .footer {
      padding: 20px;
      border-top: 1px solid var(--border);
      text-align: center;
      font-size: 12px;
      color: var(--muted);
    }

    .footer a { color: var(--orange); text-decoration: none; }
    .footer-sep { margin: 0 6px; opacity: 0.3; }
  </style>
</head>
<body>

  <div class="header">
    <div class="logo-top">WE'VE G<span class="logo-key">O</span>T THE <span class="logo-key">KEY</span></div>
    <div class="logo-sub">Auto Locksmiths</div>
  </div>

  <div class="hero">
    <div class="hero-eyebrow">Appointment Reschedule</div>
    <div class="hero-title">LET'S FIND<br>A <span>BETTER TIME.</span></div>
    <div class="hero-sub">Tell us when works best — pick as many dates as you like. Our bookings team will call to confirm.</div>
    <div class="job-badge">Job ref: <strong id="job-ref">—</strong></div>
  </div>

  <div class="form-wrap" id="form-wrap">

    <div class="form-section">
      <div class="form-label">Which days work for you?</div>
      <div class="form-hint">Tap all that apply</div>
      <div class="date-grid" id="date-grid">
        <!-- populated by JS -->
      </div>
    </div>

    <div class="form-section">
      <div class="form-label">Best time of day</div>
      <div class="time-options">

        <div class="time-option">
          <input type="radio" name="time_pref" id="am" value="AM">
          <label for="am">
            <span class="time-icon">🌅</span>
            <span class="time-text">
              <span class="time-label">Morning</span>
              <span class="time-desc">Before 1pm</span>
            </span>
            <span class="time-check"></span>
          </label>
        </div>

        <div class="time-option">
          <input type="radio" name="time_pref" id="pm" value="PM">
          <label for="pm">
            <span class="time-icon">☀️</span>
            <span class="time-text">
              <span class="time-label">Afternoon</span>
              <span class="time-desc">After 1pm</span>
            </span>
            <span class="time-check"></span>
          </label>
        </div>

        <div class="time-option">
          <input type="radio" name="time_pref" id="either" value="EITHER">
          <label for="either">
            <span class="time-icon">🕐</span>
            <span class="time-text">
              <span class="time-label">Either</span>
              <span class="time-desc">I'm flexible</span>
            </span>
            <span class="time-check"></span>
          </label>
        </div>

      </div>
    </div>

    <div class="form-section">
      <label class="form-label" for="notes">
        Anything else? <span style="color:#555;font-weight:400;text-transform:none;letter-spacing:0">(optional)</span>
      </label>
      <textarea id="notes" placeholder="e.g. Best to call after 2pm, or I'll be at a different address…"></textarea>
    </div>

    <div class="notice">
      <div class="notice-icon">ℹ️</div>
      <div class="notice-text">
        <strong>This is a preference, not a confirmed booking.</strong> Our bookings team will call you to lock in the new time.
      </div>
    </div>

    <div class="error-msg" id="error-msg">Please select at least one date and a time of day.</div>

    <button class="btn-submit" id="submit-btn" onclick="submitForm()">Send my preference →</button>

  </div>

  <div class="success-screen" id="success-screen">
    <div class="success-icon">✓</div>
    <div class="success-title">ALL <span>NOTED.</span></div>
    <div class="success-text">We've got your preferred dates. Our bookings team will call you shortly to confirm.</div>
    <div class="success-dates">
      <div class="success-dates-label">Your preferred dates</div>
      <div class="success-dates-list" id="success-dates-list"></div>
    </div>
    <div class="success-ref">Job ref: <strong id="success-ref">—</strong></div>
  </div>

  <div class="footer">
    <a href="tel:01603367100">01603 367100</a>
    <span class="footer-sep">·</span>
    <a href="mailto:info@wgtk.co.uk">info@wgtk.co.uk</a>
    <span class="footer-sep">·</span>
    <a href="https://wevegotthekey.co.uk">wevegotthekey.co.uk</a>
  </div>

  <script>
    const params = new URLSearchParams(window.location.search);
    const jobId = params.get('job') || 'Unknown';
    const clientName = params.get('name') || '';

    document.getElementById('job-ref').textContent = jobId;
    document.getElementById('success-ref').textContent = jobId;

    // Build next 10 days (skip today)
    const days = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    const fullDays = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];

    const grid = document.getElementById('date-grid');
    const dateCards = [];

    for (let i = 1; i <= 10; i++) {
      const d = new Date();
      d.setDate(d.getDate() + i);
      const isoDate = d.toISOString().split('T')[0];
      const dayShort = days[d.getDay()];
      const dayFull = fullDays[d.getDay()];
      const dateStr = `${d.getDate()} ${months[d.getMonth()]}`;
      const displayStr = `${dayFull} ${d.getDate()} ${months[d.getMonth()]}`;

      const card = document.createElement('div');
      card.className = 'date-card';
      card.dataset.date = isoDate;
      card.dataset.display = displayStr;
      card.innerHTML = `
        <span class="date-card-check"></span>
        <span class="date-card-text">
          <span class="date-card-day">${dayShort}</span>
          <span class="date-card-date">${dateStr}</span>
        </span>
      `;

      card.addEventListener('click', () => {
        card.classList.toggle('selected');
        const check = card.querySelector('.date-card-check');
        check.textContent = card.classList.contains('selected') ? '✓' : '';
      });

      grid.appendChild(card);
      dateCards.push(card);
    }

    async function submitForm() {
      const selectedDates = dateCards
        .filter(c => c.classList.contains('selected'))
        .map(c => ({ iso: c.dataset.date, display: c.dataset.display }));

      const timePref = document.querySelector('input[name="time_pref"]:checked');
      const notes = document.getElementById('notes').value.trim();
      const errEl = document.getElementById('error-msg');

      if (selectedDates.length === 0 || !timePref) {
        errEl.style.display = 'block';
        errEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }

      errEl.style.display = 'none';

      const btn = document.getElementById('submit-btn');
      btn.disabled = true;
      btn.textContent = 'Sending…';

      try {
        await fetch('https://wgtkapi.app.n8n.cloud/webhook/WAReschedule', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            job_id: jobId,
            client_name: clientName,
            preferred_dates: selectedDates.map(d => d.display).join(', '),
            preferred_dates_iso: selectedDates.map(d => d.iso).join(', '),
            time_preference: timePref.value,
            notes: notes
          })
        });

        // Success
        document.getElementById('success-dates-list').textContent =
          selectedDates.map(d => d.display).join('\n');
        document.getElementById('form-wrap').style.display = 'none';
        document.getElementById('success-screen').style.display = 'block';
        window.scrollTo({ top: 0, behavior: 'smooth' });

      } catch (e) {
        btn.disabled = false;
        btn.textContent = 'Send my preference →';
        errEl.textContent = 'Something went wrong — please call us on 01603 367100.';
        errEl.style.display = 'block';
      }
    }
  </script>

</body>
</html>
